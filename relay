#!/usr/bin/env bash
set -euo pipefail

# ============================================================
#  relay — interactive port forwarding manager for relay/jump
#  servers (3x-ui, xray, sing-box, etc.)
#
#  https://github.com/YOUR_USER/relay-manager
# ============================================================

VERSION="1.0.0"
CONFIG_DIR="/etc/relay-manager"
CONFIG_FILE="$CONFIG_DIR/config"
RULES_FILE="$CONFIG_DIR/rules"

# ── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ──────────────────────────────────────────────────
info()    { echo -e "${BLUE}ℹ${NC}  $*"; }
success() { echo -e "${GREEN}✔${NC}  $*"; }
warn()    { echo -e "${YELLOW}⚠${NC}  $*"; }
error()   { echo -e "${RED}✖${NC}  $*" >&2; }
die()     { error "$@"; exit 1; }

need_root() {
  [[ $EUID -eq 0 ]] || die "Run as root:  sudo relay $*"
}

confirm() {
  local prompt="${1:-Continue?}"
  read -r -p "$(echo -e "${YELLOW}?${NC}  ${prompt} [y/N] ")" ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# ── Config helpers ───────────────────────────────────────────
load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# relay-manager config — auto-generated
TARGET="$TARGET"
IFACE="$IFACE"
EOF
  chmod 600 "$CONFIG_FILE"
}

ensure_rules_file() {
  mkdir -p "$CONFIG_DIR"
  touch "$RULES_FILE"
  chmod 600 "$RULES_FILE"
}

# Rules file format: PORT PROTO DESCRIPTION
# Example:           443 tcp   "VLESS+Reality"

add_rule_record() {
  local port="$1" proto="$2" desc="$3"
  ensure_rules_file
  # Avoid duplicates
  if grep -q "^${port} ${proto} " "$RULES_FILE" 2>/dev/null; then
    return 1
  fi
  echo "${port} ${proto} ${desc}" >> "$RULES_FILE"
}

remove_rule_record() {
  local port="$1" proto="$2"
  ensure_rules_file
  local tmp
  tmp=$(mktemp)
  grep -v "^${port} ${proto} " "$RULES_FILE" > "$tmp" || true
  mv "$tmp" "$RULES_FILE"
}

# ── Detect environment ───────────────────────────────────────
detect_iface() {
  ip route get 8.8.8.8 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1); exit}'
}

has_ufw() {
  command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -q "active"
}

has_firewalld() {
  command -v firewall-cmd &>/dev/null && systemctl is-active --quiet firewalld 2>/dev/null
}

# ── Firewall integration ────────────────────────────────────
fw_open_port() {
  local port="$1" proto="$2"
  if has_ufw; then
    ufw allow "${port}/${proto}" >/dev/null 2>&1 && \
      info "ufw: opened ${port}/${proto}"
  elif has_firewalld; then
    firewall-cmd --permanent --add-port="${port}/${proto}" >/dev/null 2>&1
    firewall-cmd --reload >/dev/null 2>&1
    info "firewalld: opened ${port}/${proto}"
  fi
}

fw_close_port() {
  local port="$1" proto="$2"
  if has_ufw; then
    ufw delete allow "${port}/${proto}" >/dev/null 2>&1 && \
      info "ufw: closed ${port}/${proto}"
  elif has_firewalld; then
    firewall-cmd --permanent --remove-port="${port}/${proto}" >/dev/null 2>&1
    firewall-cmd --reload >/dev/null 2>&1
    info "firewalld: closed ${port}/${proto}"
  fi
}

# ── UFW NAT rules (before.rules) ────────────────────────────
UFW_BEFORE="/etc/ufw/before.rules"
UFW_MARKER_START="# >>> relay-manager NAT rules"
UFW_MARKER_END="# <<< relay-manager NAT rules"

ufw_rebuild_nat() {
  [[ -f "$UFW_BEFORE" ]] || return 0
  has_ufw || return 0

  load_config
  ensure_rules_file

  local tmp
  tmp=$(mktemp)

  # Remove old relay-manager block
  sed "/${UFW_MARKER_START}/,/${UFW_MARKER_END}/d" "$UFW_BEFORE" > "$tmp"

  # Build new NAT block
  local nat_block=""
  nat_block+="${UFW_MARKER_START}\n"
  nat_block+="*nat\n"
  nat_block+=":PREROUTING ACCEPT [0:0]\n"
  nat_block+=":POSTROUTING ACCEPT [0:0]\n"

  while IFS=' ' read -r port proto desc; do
    [[ -z "$port" || "$port" == "#"* ]] && continue
    nat_block+="-A PREROUTING -i ${IFACE} -p ${proto} --dport ${port} -j DNAT --to-destination ${TARGET}:${port}\n"
  done < "$RULES_FILE"

  nat_block+="-A POSTROUTING -d ${TARGET} -j MASQUERADE\n"
  nat_block+="COMMIT\n"
  nat_block+="${UFW_MARKER_END}\n"

  # Insert at the very top of the file
  echo -e "${nat_block}" | cat - "$tmp" > "${UFW_BEFORE}"
  rm -f "$tmp"

  # Ensure forwarding policy
  sed -i 's/^DEFAULT_FORWARD_POLICY=.*/DEFAULT_FORWARD_POLICY="ACCEPT"/' /etc/default/ufw 2>/dev/null || true

  ufw reload >/dev/null 2>&1
  info "ufw: NAT rules rebuilt"
}

# ── iptables operations ──────────────────────────────────────
ipt_add() {
  local port="$1" proto="$2"
  load_config

  iptables -t nat -C PREROUTING -i "$IFACE" -p "$proto" --dport "$port" \
    -j DNAT --to-destination "${TARGET}:${port}" 2>/dev/null && {
    warn "iptables rule already exists: ${port}/${proto}"
    return 0
  }

  iptables -t nat -A PREROUTING -i "$IFACE" -p "$proto" --dport "$port" \
    -j DNAT --to-destination "${TARGET}:${port}"
}

ipt_remove() {
  local port="$1" proto="$2"
  load_config

  iptables -t nat -D PREROUTING -i "$IFACE" -p "$proto" --dport "$port" \
    -j DNAT --to-destination "${TARGET}:${port}" 2>/dev/null || true
}

ipt_ensure_postrouting() {
  load_config
  iptables -t nat -C POSTROUTING -d "$TARGET" -j MASQUERADE 2>/dev/null || \
    iptables -t nat -A POSTROUTING -d "$TARGET" -j MASQUERADE
}

ipt_ensure_forward() {
  load_config
  iptables -C FORWARD -d "$TARGET" -j ACCEPT 2>/dev/null || \
    iptables -A FORWARD -d "$TARGET" -j ACCEPT
  iptables -C FORWARD -s "$TARGET" -j ACCEPT 2>/dev/null || \
    iptables -A FORWARD -s "$TARGET" -j ACCEPT
}

ipt_persist() {
  if command -v netfilter-persistent &>/dev/null; then
    netfilter-persistent save >/dev/null 2>&1
    info "iptables rules persisted"
  else
    warn "iptables-persistent not installed — rules won't survive reboot"
    warn "Run:  apt install -y iptables-persistent"
  fi
}

# ── Commands ─────────────────────────────────────────────────

cmd_init() {
  need_root "init"

  echo -e "${BOLD}${CYAN}"
  echo "  ┌─────────────────────────────────────┐"
  echo "  │     relay-manager — initial setup    │"
  echo "  └─────────────────────────────────────┘"
  echo -e "${NC}"

  # Target IP
  local current_target="${TARGET:-}"
  read -r -p "$(echo -e "${CYAN}?${NC}  Target server IP (3x-ui) ${current_target:+[$current_target]}: ")" input_target
  TARGET="${input_target:-$current_target}"
  [[ -n "$TARGET" ]] || die "Target IP is required"

  # Validate IP/hostname reachability
  if ping -c 1 -W 2 "$TARGET" &>/dev/null; then
    success "Target $TARGET is reachable"
  else
    warn "Target $TARGET is not responding to ping (may be fine if ICMP is blocked)"
  fi

  # Interface
  local detected_iface
  detected_iface=$(detect_iface)
  read -r -p "$(echo -e "${CYAN}?${NC}  Network interface [${detected_iface}]: ")" input_iface
  IFACE="${input_iface:-$detected_iface}"
  [[ -n "$IFACE" ]] || die "Interface is required"

  # Enable IP forwarding
  if [[ "$(sysctl -n net.ipv4.ip_forward)" != "1" ]]; then
    info "Enabling ip_forward..."
    sysctl -w net.ipv4.ip_forward=1 >/dev/null
    sed -i '/^#\?net\.ipv4\.ip_forward/c\net.ipv4.ip_forward = 1' /etc/sysctl.conf
    success "IP forwarding enabled"
  else
    success "IP forwarding already enabled"
  fi

  # Install iptables-persistent if missing
  if ! command -v netfilter-persistent &>/dev/null; then
    if confirm "Install iptables-persistent for rule persistence?"; then
      info "Installing iptables-persistent..."
      DEBIAN_FRONTEND=noninteractive apt-get install -y iptables-persistent >/dev/null 2>&1
      success "iptables-persistent installed"
    fi
  fi

  save_config
  ensure_rules_file

  success "Config saved to ${CONFIG_FILE}"
  echo ""
  info "Next steps:"
  echo "    relay add 443 tcp \"VLESS+Reality\""
  echo "    relay add 2053 tcp \"3x-ui panel\""
  echo "    relay list"
}

cmd_add() {
  need_root "add"
  load_config
  [[ -n "${TARGET:-}" ]] || die "Run 'relay init' first"

  local port="${1:-}"
  local proto="${2:-tcp}"
  local desc="${3:-}"

  # Interactive mode if no args
  if [[ -z "$port" ]]; then
    read -r -p "$(echo -e "${CYAN}?${NC}  Port: ")" port
    [[ -n "$port" ]] || die "Port is required"

    echo -e "  ${BOLD}1)${NC} tcp"
    echo -e "  ${BOLD}2)${NC} udp"
    echo -e "  ${BOLD}3)${NC} both"
    read -r -p "$(echo -e "${CYAN}?${NC}  Protocol [1]: ")" proto_choice
    case "${proto_choice:-1}" in
      1) proto="tcp" ;;
      2) proto="udp" ;;
      3) proto="both" ;;
      *) proto="tcp" ;;
    esac

    read -r -p "$(echo -e "${CYAN}?${NC}  Description (optional): ")" desc
  fi

  # Validate port
  if ! [[ "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
    die "Invalid port: $port"
  fi

  local protos=()
  if [[ "$proto" == "both" ]]; then
    protos=(tcp udp)
  else
    protos=("$proto")
  fi

  for p in "${protos[@]}"; do
    # iptables
    ipt_add "$port" "$p"
    ipt_ensure_postrouting
    ipt_ensure_forward

    # Firewall
    fw_open_port "$port" "$p"

    # Record
    if add_rule_record "$port" "$p" "${desc:-unnamed}"; then
      success "Added: ${BOLD}${port}/${p}${NC} → ${TARGET}:${port}  ${desc:+(${desc})}"
    else
      warn "Rule ${port}/${p} already exists in config"
    fi
  done

  ipt_persist

  # Rebuild UFW NAT if active
  if has_ufw; then
    ufw_rebuild_nat
  fi
}

cmd_remove() {
  need_root "remove"
  load_config
  [[ -n "${TARGET:-}" ]] || die "Run 'relay init' first"

  local port="${1:-}"
  local proto="${2:-}"

  if [[ -z "$port" ]]; then
    cmd_list
    echo ""
    read -r -p "$(echo -e "${CYAN}?${NC}  Port to remove: ")" port
    [[ -n "$port" ]] || die "Port is required"

    read -r -p "$(echo -e "${CYAN}?${NC}  Protocol (tcp/udp/both) [both]: ")" proto
    proto="${proto:-both}"
  fi

  local protos=()
  if [[ "$proto" == "both" || -z "$proto" ]]; then
    protos=(tcp udp)
  else
    protos=("$proto")
  fi

  for p in "${protos[@]}"; do
    ipt_remove "$port" "$p"
    fw_close_port "$port" "$p"
    remove_rule_record "$port" "$p"
    success "Removed: ${port}/${p}"
  done

  ipt_persist

  if has_ufw; then
    ufw_rebuild_nat
  fi
}

cmd_list() {
  load_config
  ensure_rules_file

  echo -e "\n${BOLD}  relay-manager v${VERSION}${NC}"
  echo -e "  Target: ${CYAN}${TARGET:-not configured}${NC}"
  echo -e "  Interface: ${CYAN}${IFACE:-not configured}${NC}"

  if has_ufw; then
    echo -e "  Firewall: ${GREEN}ufw (active)${NC}"
  elif has_firewalld; then
    echo -e "  Firewall: ${GREEN}firewalld (active)${NC}"
  else
    echo -e "  Firewall: ${YELLOW}none detected${NC}"
  fi

  echo ""

  if [[ ! -s "$RULES_FILE" ]]; then
    warn "No forwarding rules configured"
    echo "    Run:  relay add <port> <proto> [description]"
    return
  fi

  printf "  ${BOLD}%-8s %-8s %-30s %s${NC}\n" "PORT" "PROTO" "DESCRIPTION" "STATUS"
  echo "  ──────────────────────────────────────────────────────────"

  while IFS=' ' read -r port proto desc; do
    [[ -z "$port" || "$port" == "#"* ]] && continue

    # Check if iptables rule is live
    local status="${RED}inactive${NC}"
    if iptables -t nat -C PREROUTING -i "$IFACE" -p "$proto" --dport "$port" \
       -j DNAT --to-destination "${TARGET}:${port}" 2>/dev/null; then
      status="${GREEN}active${NC}"
    fi

    printf "  %-8s %-8s %-30s " "$port" "$proto" "$desc"
    echo -e "$status"
  done < "$RULES_FILE"

  echo ""
}

cmd_status() {
  load_config
  echo -e "\n${BOLD}  System status${NC}\n"

  # IP forward
  local fwd
  fwd=$(sysctl -n net.ipv4.ip_forward 2>/dev/null)
  if [[ "$fwd" == "1" ]]; then
    echo -e "  ip_forward:         ${GREEN}enabled${NC}"
  else
    echo -e "  ip_forward:         ${RED}disabled${NC}"
  fi

  # Target reachability
  if [[ -n "${TARGET:-}" ]]; then
    if ping -c 1 -W 2 "$TARGET" &>/dev/null; then
      echo -e "  target ($TARGET): ${GREEN}reachable${NC}"
    else
      echo -e "  target ($TARGET): ${YELLOW}unreachable (ICMP)${NC}"
    fi
  fi

  # iptables-persistent
  if command -v netfilter-persistent &>/dev/null; then
    echo -e "  persistence:        ${GREEN}iptables-persistent${NC}"
  else
    echo -e "  persistence:        ${RED}not installed${NC}"
  fi

  # Firewall
  if has_ufw; then
    echo -e "  firewall:           ${GREEN}ufw (active)${NC}"
  elif has_firewalld; then
    echo -e "  firewall:           ${GREEN}firewalld (active)${NC}"
  else
    echo -e "  firewall:           ${YELLOW}none${NC}"
  fi

  echo ""

  # Show NAT table
  echo -e "  ${BOLD}NAT PREROUTING rules:${NC}"
  iptables -t nat -L PREROUTING -n --line-numbers 2>/dev/null | sed 's/^/    /'
  echo ""
}

cmd_apply() {
  need_root "apply"
  load_config
  ensure_rules_file
  [[ -n "${TARGET:-}" ]] || die "Run 'relay init' first"

  info "Re-applying all rules from ${RULES_FILE}..."

  while IFS=' ' read -r port proto desc; do
    [[ -z "$port" || "$port" == "#"* ]] && continue
    ipt_add "$port" "$proto"
    fw_open_port "$port" "$proto"
  done < "$RULES_FILE"

  ipt_ensure_postrouting
  ipt_ensure_forward
  ipt_persist

  if has_ufw; then
    ufw_rebuild_nat
  fi

  success "All rules applied"
}

cmd_flush() {
  need_root "flush"

  if ! confirm "Remove ALL relay forwarding rules?"; then
    return
  fi

  load_config
  ensure_rules_file

  # Remove iptables rules
  while IFS=' ' read -r port proto desc; do
    [[ -z "$port" || "$port" == "#"* ]] && continue
    ipt_remove "$port" "$proto"
    fw_close_port "$port" "$proto"
  done < "$RULES_FILE"

  # Remove MASQUERADE and FORWARD rules
  if [[ -n "${TARGET:-}" ]]; then
    iptables -t nat -D POSTROUTING -d "$TARGET" -j MASQUERADE 2>/dev/null || true
    iptables -D FORWARD -d "$TARGET" -j ACCEPT 2>/dev/null || true
    iptables -D FORWARD -s "$TARGET" -j ACCEPT 2>/dev/null || true
  fi

  # Clear rules file
  > "$RULES_FILE"

  ipt_persist

  if has_ufw; then
    ufw_rebuild_nat
  fi

  success "All relay rules flushed"
}

cmd_uninstall() {
  need_root "uninstall"

  echo -e "${BOLD}${RED}  This will remove relay-manager and all its rules.${NC}"

  if ! confirm "Are you sure?"; then
    return
  fi

  cmd_flush

  rm -rf "$CONFIG_DIR"
  rm -f /usr/local/bin/relay

  success "relay-manager uninstalled"
}

cmd_help() {
  echo -e "
${BOLD}relay${NC} v${VERSION} — port forwarding manager for relay/jump servers

${BOLD}USAGE${NC}
    relay <command> [args]

${BOLD}COMMANDS${NC}
    ${GREEN}init${NC}                          Initial setup (target IP, interface, ip_forward)
    ${GREEN}add${NC}  [port] [proto] [desc]     Add port forwarding rule
    ${GREEN}remove${NC} [port] [proto]          Remove port forwarding rule
    ${GREEN}list${NC}                           List all configured rules
    ${GREEN}status${NC}                         Show system status & diagnostics
    ${GREEN}apply${NC}                          Re-apply all rules from config
    ${GREEN}flush${NC}                          Remove all forwarding rules
    ${GREEN}uninstall${NC}                      Remove relay-manager completely
    ${GREEN}help${NC}                           Show this help

${BOLD}EXAMPLES${NC}
    relay init
    relay add 443 tcp \"VLESS+Reality\"
    relay add 8443 both \"Hysteria2\"
    relay add                          ${YELLOW}# interactive mode${NC}
    relay remove 443 tcp
    relay list
    relay status

${BOLD}FILES${NC}
    ${CONFIG_FILE}       Configuration
    ${RULES_FILE}        Forwarding rules
"
}

# ── Main dispatcher ──────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)       cmd_init "$@" ;;
    add)        cmd_add "$@" ;;
    remove|rm)  cmd_remove "$@" ;;
    list|ls)    cmd_list "$@" ;;
    status|st)  cmd_status "$@" ;;
    apply)      cmd_apply "$@" ;;
    flush)      cmd_flush "$@" ;;
    uninstall)  cmd_uninstall "$@" ;;
    help|-h|--help) cmd_help ;;
    version|-v|--version) echo "relay v${VERSION}" ;;
    *)          error "Unknown command: $cmd"; cmd_help; exit 1 ;;
  esac
}

main "$@"
